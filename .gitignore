# Backups (large zip files)
backups/

# Manifests (per-run snapshots - local only)
manifests/

# Python
__pycache__/
*.pyc
.venv/

# LiDAR (large, regenerable from USGS cache)
data/*.tif
data/*.laz

# Credentials - never commit
.env
/.direnv

# Server properties (contains RCON password)
server.properties
server/server.properties

# Build artifacts
/target
**/*.rs.bk

# IDE/editor files
.idea/
/.vscode/
/*.swp
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln

# System files
.DS_Store
Thumbs.db
*.tmp
*.log

# Generated files
/export.json
/parsed_osm_data.txt
/elevation_debug.png
/terrain-tile-cache
/arnis-tile-cache
/gen/
/build/
*.rmeta
*.dSYM

# Tauri specific
flake/
gen/

# Miscellaneous
*.bak
*.old
*.orig
/wiki
*.mcworld

# Ignore all in flake directory except specific files
/flake/*
!/flake/flake.nix
!/flake/flake.lock